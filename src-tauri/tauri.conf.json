{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "质量分析平台",
  "version": "1.0.0",
  "identifier": "com.quality.platform",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5188",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "质量分析平台 · Quality Analytics Platform",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "installMode": "perMachine"
      }
    }
  }
}
