{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "质量分析平台",
  "version": "1.11.0",
  "identifier": "com.quality.platform",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5188",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "质量分析平台 · Quality Analytics Platform",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": [
          "SimpChinese"
        ],
        "installMode": "perMachine"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBNkQ1M0Y1RDk2MTQ4MjkKUldRcFNHSFo5Vk50bWtTQjVQRUx5Ty9JckVJTWxpNWwrWTJkeXFsaFpja2xwb1dTWldZUUI0VE0K",
      "endpoints": [
        "https://github.com/nihantao-crosis/quality-platform/releases/latest/download/latest.json"
      ]
    }
  }
}